/* pages/index/index.wxss */

/* 容器 */
.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: var(--bg-dark);
}

/* 界面切换 */
.screen {
  display: none;
  width: 100%;
  animation: fadeIn 0.3s ease;
}

.screen.active {
  display: flex;
  flex-direction: column;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 用户名设置界面 */
.name-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 50rpx;
}

.logo-icon {
  font-size: 160rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.name-title {
  font-size: 56rpx;
  font-weight: 700;
  text-align: center;
  color: var(--text-primary);
}

.name-subtitle {
  font-size: 32rpx;
  color: var(--text-secondary);
  text-align: center;
}

.name-input {
  width: 100%;
  max-width: 600rpx;
  padding: 32rpx 40rpx;
  font-size: 36rpx;
  color: var(--text-primary);
  background: var(--bg-card);
  border: 4rpx solid var(--bg-hover);
  border-radius: 24rpx;
  text-align: center;
}

/* 游戏介绍界面 */
.intro-content {
  width: 100%;
  max-width: 800rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 60rpx;
}

.intro-header {
  text-align: center;
}

.intro-title {
  font-size: 72rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, var(--primary-start) 0%, var(--primary-end) 100%);
  -webkit-background-clip: text;
  color: transparent;
}

.intro-tag {
  color: var(--text-secondary);
  font-size: 32rpx;
  letter-spacing: 4rpx;
}

.intro-demo {
  position: relative;
  padding: 40rpx;
  background: rgba(30, 41, 59, 0.5);
  border-radius: 40rpx;
}

.demo-grid {
  display: grid;
  grid-template-columns: repeat(2, 120rpx);
  grid-template-rows: repeat(2, 120rpx);
  gap: 20rpx;
  position: relative;
}

.demo-cell {
  background: var(--bg-card);
  border: 4rpx solid var(--bg-hover);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.cursor-hand {
  position: absolute;
  font-size: 64rpx;
  top: 50%;
  left: 50%;
  pointer-events: none;
  z-index: 10;
  animation: demoHand 4s infinite ease-in-out;
}

@keyframes demoHand {
  0% { top: 110%; left: 110%; opacity: 0; }
  10% { top: 25%; left: 75%; opacity: 1; }
  15% { transform: scale(0.8); }
  20% { transform: scale(1); }
  35% { top: 75%; left: 75%; }
  40% { transform: scale(0.8); }
  45% { transform: scale(1); }
  60% { top: 75%; left: 25%; }
  65% { transform: scale(0.8); }
  70% { transform: scale(1); }
  85% { top: 25%; left: 25%; }
  90% { transform: scale(0.8); }
  95% { transform: scale(1); opacity: 1; }
  100% { top: 110%; left: 110%; opacity: 0; }
}

.intro-rules {
  text-align: center;
  background: var(--bg-card);
  padding: 40rpx;
  border-radius: 32rpx;
  width: 100%;
}

.rule-item {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.bold {
  color: var(--text-primary);
  font-weight: 700;
}

/* 教程界面 */
.tutorial-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.tutorial-icon {
  font-size: 120rpx;
}

.tutorial-timer {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  background: rgba(30, 41, 59, 0.5);
  padding: 10rpx 30rpx;
  border-radius: 16rpx;
}

.tutorial-hint {
  color: var(--text-secondary);
  font-size: 28rpx;
}

.tutorial-demo-container {
  width: 100%;
  max-width: 640rpx;
}

.tutorial-grid {
  pointer-events: auto;
}

/* 主菜单 */
.logo {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 96rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--primary-start) 0%, var(--primary-end) 100%);
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 30rpx;
}

.player-profile {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 20rpx;
}

.player-name-text {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.edit-hint {
  font-size: 24rpx;
  color: var(--accent-purple);
  opacity: 0.8;
}

.subtitle {
  font-size: 36rpx;
  color: var(--text-secondary);
}

.difficulty-selector {
  width: 100%;
  margin: 40rpx 0;
}

.section-title {
  font-size: 40rpx;
  margin-bottom: 40rpx;
  text-align: center;
  color: var(--text-secondary);
}

.difficulty-buttons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.difficulty-btn {
  background: var(--bg-card);
  border: 4rpx solid transparent;
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.difficulty-btn.active {
  border-color: var(--accent-purple);
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(59, 130, 246, 0.2) 100%);
}

.diff-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.diff-size {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
}

/* 按钮 */
.primary-btn {
  width: 100%;
  padding: 36rpx 64rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  background: linear-gradient(135deg, var(--primary-start) 0%, var(--primary-end) 100%);
  border: none;
  border-radius: 32rpx;
  margin-top: 20rpx;
}

.secondary-btn {
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  background: var(--bg-card);
  border: 4rpx solid var(--bg-hover);
  border-radius: 24rpx;
  margin-top: 20rpx;
}

.pk-btn {
  border-color: var(--accent-purple);
}

.icon-btn {
  width: 88rpx;
  height: 88rpx;
  font-size: 48rpx;
  color: var(--text-primary);
  background: var(--bg-card);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 最佳成绩 */
.best-records {
  width: 100%;
  background: var(--bg-card);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-top: 40rpx;
  overflow: hidden; /* 防止内部项目圆角溢出导致视觉上歪了 */
  box-sizing: border-box;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.no-records {
  text-align: center;
  color: var(--text-secondary);
  padding: 40rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-dark);
  border-radius: 20rpx;
}

.record-difficulty {
  font-weight: 600;
  color: var(--text-primary);
}

.record-time {
  font-weight: 700;
  color: var(--accent-green);
}

/* 游戏界面 */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.timer-display {
  flex: 1;
  text-align: center;
}

.timer-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.timer {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--secondary-start) 0%, var(--secondary-end) 100%);
  -webkit-background-clip: text;
  color: transparent;
}

.progress-info {
  font-size: 36rpx;
  font-weight: 700;
}

.current-num {
  color: var(--accent-green);
  font-size: 48rpx;
}

.total-num {
  color: var(--text-secondary);
}

/* 游戏网格 */
.game-grid {
  display: grid;
  gap: 20rpx;
  width: 100%;
  aspect-ratio: 1;
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: 40rpx;
}

.grid-cell {
  background: var(--bg-dark);
  border: 4rpx solid var(--bg-hover);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.grid-cell.found {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.3) 0%, rgba(6, 182, 212, 0.3) 100%);
  border-color: var(--accent-green);
  color: var(--accent-green);
  animation: found 0.4s ease;
}

@keyframes found {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.grid-cell.wrong {
  border-color: #EF4444;
  color: #EF4444;
  animation: shake 0.4s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-10rpx); }
  40%, 80% { transform: translateX(10rpx); }
}

.game-controls {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

/* 结果界面 */
.result-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.result-icon {
  font-size: 120rpx;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-header-group {
  text-align: center;
}

.result-player-name {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.result-psych-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent-purple);
  margin-bottom: 16rpx;
}

.result-psych-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.result-stats {
  display: flex;
  gap: 40rpx;
  width: 100%;
  justify-content: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.stat-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.stat-value {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.stat-rank {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--accent-purple);
}

.stat-rank.rank-s {
  animation: s-rank-pulse 0.5s ease infinite alternate;
  color: #F59E0B;
}

@keyframes s-rank-pulse {
  from { transform: scale(1); }
  to { transform: scale(1.1); }
}

.new-record {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--accent-green);
  padding: 16rpx 32rpx;
  background: rgba(16, 185, 129, 0.2);
  border-radius: 16rpx;
}

.new-record.hidden {
  display: none;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* PK界面 */
.pk-inputs {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.vs-text {
  font-weight: bold;
  color: var(--accent-purple);
  font-size: 40rpx;
}

.pk-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  margin-top: 40rpx;
}

.pk-winner-name {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin: 20rpx 0;
}

.pk-winner-time {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--accent-green);
}

.pk-loser-card {
  background: rgba(30, 41, 59, 0.5);
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.loser-label {
  color: #CBD5E1;
}

.loser-name {
  color: #CBD5E1;
  font-weight: bold;
  margin-left: 10rpx;
}

.loser-time {
  color: #94A3B8;
  margin-left: 20rpx;
}

/* “大脑解毒剂” 弹窗样式 */
.hero-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}

.hero-modal-mask.active {
  opacity: 1;
  visibility: visible;
}

.hero-modal-content {
  width: 80%;
  max-width: 560rpx;
  background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 48rpx;
  padding: 50rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: scale(0.9);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.5);
}

.hero-modal-mask.active .hero-modal-content {
  transform: scale(1);
}

.hero-modal-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.hero-modal-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  animation: heroIconFloat 2.5s ease-in-out infinite;
}

@keyframes heroIconFloat {
  0%, 100% { transform: translateY(0) scale(1.0); }
  50% { transform: translateY(-15rpx) scale(1.1); }
}

.hero-modal-title {
  font-size: 38rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 100%);
  -webkit-background-clip: text;
  color: transparent;
}

.hero-modal-body {
  margin-bottom: 50rpx;
}

.hero-text-p {
  display: block;
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  text-align: center;
  margin-bottom: 24rpx;
}

.hero-btn {
  margin-top: 0;
  box-shadow: 0 10rpx 30rpx rgba(59, 130, 246, 0.3);
}

.hero-text-line {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  text-align: center;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.intro-break {
  opacity: 0.2;
  margin: 20rpx 0;
  font-size: 24rpx;
}
/* 荣耀分享按钮特效 */
.share-glow-btn {
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 30rpx rgba(139, 92, 246, 0.4);
  animation: buttonGlow 2s infinite alternate;
}

@keyframes buttonGlow {
  from { box-shadow: 0 0 20rpx rgba(139, 92, 246, 0.3); }
  to { box-shadow: 0 0 50rpx rgba(59, 130, 246, 0.6); }
}

/* 撒花特效 */
.confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 100;
  overflow: hidden;
}

.confetti {
  position: absolute;
  top: -20rpx;
  width: 15rpx;
  height: 15rpx;
  border-radius: 2rpx;
  animation: fall 3s linear forwards;
}

@keyframes fall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  70% {
    opacity: 1;
  }
  100% {
    transform: translateY(120vh) rotate(720deg);
    opacity: 0;
  }
}

/* 分享图画布 (隐藏在屏幕外) */
.share-canvas {
  position: fixed;
  left: -2000px;
  top: 0;
  width: 750px;
  height: 600px;
}
